{
  "luci-app-zapret2": {
    "description": "Grant access to Zapret2 status and service control",
    "read": {
      "file": {
        "/opt/zapret2/config": [ "read" ],
        "/etc/init.d/zapret2": [ "exec" ],
        "/opt/zapret2/nfq2/nfqws2": [ "exec" ]
      },
      "ubus": {
        "luci": [ "getInitList", "setInitAction" ],
        "service": [ "list" ]
      }
    }
  }
}
